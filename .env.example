APP_ENV=local
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Model gateway
MODEL_PROVIDER=azure_openai
MODEL_NAME=gpt-4.1-mini
AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure services
AZURE_REGION=australiaeast
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_SEARCH_ENDPOINT=https://roadsense-search.search.windows.net
AZURE_SEARCH_API_KEY=replace-me
AZURE_SEARCH_INDEX=roadsense-policy-chunks
COSMOS_ENDPOINT=https://roadsense-cosmos.documents.azure.com:443/
COSMOS_KEY=replace-me
COSMOS_DATABASE=roadsense

# Local services
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://roadsense:roadsense@localhost:5432/roadsense
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# Safety
PII_HASH_SALT=replace-me
HUMAN_HANDOFF_THRESHOLD=0.72
